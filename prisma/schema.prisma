datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// NextAuth Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  credits       Float     @default(0.0) // Gaming hours/credits ledger
  
  isOnline       Boolean   @default(false)
  lastActive     DateTime? @default(now())
  isBlocked      Boolean   @default(false)

  accounts         Account[]
  sessions         Session[]
  transactions     Transaction[]
  tournamentEntries TournamentEntry[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
}

// Custom Models
model Package {
  id          String   @id @default(cuid())
  name        String   // e.g., "VIP", "Day Pass"
  description String
  price       Float
  credits     Float    // How many credits this package gives
  active      Boolean  @default(true)
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Float
  type      TxType   // e.g., "PURCHASE", "SPEND", "TOPUP"
  status    TxStatus @default(PENDING)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Tournament {
  id           String   @id @default(cuid())
  title        String
  game         String   // e.g., "Valorant", "CS2"
  entryFee     Float
  prizePool    Float
  startDate    DateTime
  status       TourneyStatus @default(UPCOMING)

  entries      TournamentEntry[]
}

model TournamentEntry {
  id           String   @id @default(cuid())
  userId       String
  tournamentId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  tournament Tournament @relation(fields: [tournamentId], references: [id])
}

enum TxType {
  CREDIT_PURCHASE
  TOURNAMENT_ENTRY
}

enum TxStatus {
  PENDING
  COMPLETED
  FAILED
}

enum TourneyStatus {
  UPCOMING
  ONGOING
  COMPLETED
}
